-- print the table
SELECT * FROM STUDENT;
SELECT * FROM WORKER;

-- use of where
SELECT * FROM STUDENT WHERE Age >20;
select sname,city from student where age >19;

-- use of between
select * from student where age between 19 and 21;

-- use of in
select * from student where course ='btech' or course ='bca';
select * from student where course in ('btech','bca');

-- wildcard or pattern identification
select * from student where sname like '_o%';
select * from student where sname like '%a%';

-- sorting 
select * from worker order by salary;
select * from worker order by salary desc;

-- distinct values
select distinct dept from worker; 

-- data grouping 
select dept,count(*) from worker group by dept;
select dept,avg(salary) from worker group by dept;
select dept,max(salary) from worker group by dept;
select dept,min(salary) from worker group by dept;
select dept,sum(salary) from worker group by dept;

-- data grouping with having or specific conditions\
select dept from worker group by dept having count(dept)>1;
